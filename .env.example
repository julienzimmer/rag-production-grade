# ============================================================
# .env.example — Copier vers .env et remplir les valeurs
# NE JAMAIS committer .env dans le dépôt git
# ============================================================

# --- APPLICATION ---
APP_NAME="RAG Production Grade"
APP_VERSION="0.1.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# --- API ---
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# --- BASE DE DONNÉES ---
# Local (docker-compose) :
DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/rag_db
# Supabase (cloud) :
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- VECTOR STORE ---
EMBEDDING_DIMENSION=1536          # text-embedding-3-small par défaut
VECTOR_DISTANCE_METRIC=cosine     # cosine | l2 | inner_product

# --- LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- SUPABASE ---
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- OBSERVABILITÉ ---
# LangSmith — https://smith.langchain.com
# Trace automatique des appels LangChain (ChatOpenAI) — aucun code requis
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=rag-production-grade
# Passer à true pour activer le tracing LangSmith
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY = même valeur que LANGSMITH_API_KEY
# (LangChain lit ce nom de variable, pas LANGSMITH_API_KEY)
LANGCHAIN_API_KEY=ls__...

# Langfuse — https://cloud.langfuse.com
# Trace le pipeline RAG complet (embed → retrieve → generate)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- AWS ---
AWS_REGION=eu-west-1
AWS_S3_BUCKET=rag-production-grade-docs
# En production : utiliser les IAM roles, pas les clés ici.
# En dev local uniquement :
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
